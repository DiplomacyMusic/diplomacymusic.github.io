---
import Layout from '../layouts/Layout.astro';
import credits from '../data/credits.json';
---

<Layout
  title="Index. Every Diplomacy credit."
  description="Every Diplomacy credit on one fast page. Titles, roles, publishers, and where to listen."
  withSound={false}
>
  <main class="wrap">
    <header class="index-head">
      <h1>Index</h1>
      <p class="lede">Everything, plainly. {credits.length} credits.</p>
    </header>

    <ul class="credit-list">
      {credits.map((credit) => (
        <li class="credit-row">
          <div class="credit-main">
            <h2 class="credit-title">{credit.title}</h2>
            <p class="credit-roles">{credit.roles.join(', ')}</p>
          </div>
          <div class="credit-side">
            <p class="credit-pub">
              {credit.publisher}
              {credit.genre && <span class="genre"> · {credit.genre}</span>}
            </p>
            <p class="credit-facts">
              {credit.badges.map((badge) => <span class="badge">{badge}</span>)}
            </p>
            <p class="credit-links">
              {credit.links.apple && <a href={credit.links.apple}>Apple</a>}
              {credit.links.spotify && <a href={credit.links.spotify}>Spotify</a>}
              {credit.links.official && <a href={credit.links.official}>Listen</a>}
            </p>
          </div>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  .index-head {
    padding-block: var(--space-4) var(--space-3);
  }

  .lede {
    color: var(--ink-quiet);
  }

  .credit-list {
    list-style: none;
    margin: 0 0 var(--space-4);
    padding: 0;
  }

  .credit-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.3rem var(--space-3);
    padding-block: var(--space-2);
    border-top: 1px solid var(--haze);
  }

  @media (min-width: 700px) {
    .credit-row {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .credit-title {
    font-size: 1.15rem;
    margin: 0;
  }

  .credit-roles {
    color: var(--ink-quiet);
    font-size: 0.9rem;
    margin: 0;
  }

  .credit-side p {
    margin: 0 0 0.25rem;
    font-size: 0.9rem;
  }

  .credit-pub {
    color: var(--ink);
  }

  .genre {
    color: var(--ink-quiet);
  }

  .credit-facts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .credit-links {
    display: flex;
    gap: var(--space-2);
  }
</style>
