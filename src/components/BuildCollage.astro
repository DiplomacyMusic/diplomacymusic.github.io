---
// The Build section, pared to its shared interface: patch cables,
// the experimental score, and a live log. The code is real: every
// strike, swell, throw, and landing in the environment broadcasts a
// line, and this field types it out as it happens. No panels, no
// boxes, no props.
---

<div class="collage" id="build-stage" aria-hidden="true">
  <svg class="field cables" viewBox="0 0 1200 520" preserveAspectRatio="xMidYMid slice">
    <g class="jacks" fill="none" stroke-width="1.4"></g>
    <g class="cable-paths" fill="none" stroke-width="3.5" stroke-linecap="round"></g>
  </svg>

  <div class="field code">
    <pre><code id="build-code"></code></pre>
  </div>

  <div class="field scorebed" id="build-scorebed"></div>
</div>

<style>
  .collage {
    position: relative;
    height: clamp(380px, 56vh, 600px);
    margin-block: var(--space-3);
  }

  .field {
    position: absolute;
    pointer-events: none;
  }

  .cables {
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.5;
  }

  /* the transcript owns the right side, a full column of it */
  .code {
    right: 2%;
    top: 2%;
    bottom: 2%;
    width: 36%;
    display: flex;
    align-items: flex-end;
  }

  .code pre {
    margin: 0;
    font-family: 'SF Mono', Menlo, monospace;
    font-size: 0.78rem;
    line-height: 1.9;
    color: var(--ink-quiet);
    white-space: pre-wrap;
    /* the past fades upward, like the staff's oldest notes */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 38%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 38%);
  }

  .scorebed {
    inset: 0;
  }

  @media (max-width: 760px) {
    .code {
      right: 4%;
      width: 70%;
    }
  }
</style>

<script>
  import { createScoreLayer } from '../scripts/score-layer.js';

  const NS = 'http://www.w3.org/2000/svg';
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const stage = document.getElementById('build-stage');

  // the live transcript: the environment broadcasts every interaction
  const SEED = '// the room, as it happens';
  const MAX_LINES = 16; // a full column down the right side

  // TODO (Daniel): cables should sway with the room physics
  // TODO (Daniel): cables become repatchable by hand; the patching will
  //                get a real function later

  // jacks scattered like stars, cables sagging between near neighbors
  const JACKS = Array.from({ length: 16 }, (_, i) => [
    60 + (i % 8) * 155 + ((i * 73) % 50),
    70 + Math.floor(i / 8) * 250 + ((i * 137) % 90),
  ]);
  const CABLE_COLOR = ['#849396', '#4e433d', '#979595', '#67635b', '#849396', '#4e433d'];

  function drawField(animate) {
    const jackGroup = stage.querySelector('.jacks');
    const cableGroup = stage.querySelector('.cable-paths');
    for (const [x, y] of JACKS) {
      const ring = document.createElementNS(NS, 'circle');
      ring.setAttribute('cx', x);
      ring.setAttribute('cy', y);
      ring.setAttribute('r', 8);
      ring.setAttribute('stroke', '#67635b');
      jackGroup.appendChild(ring);
      const pin = document.createElementNS(NS, 'circle');
      pin.setAttribute('cx', x);
      pin.setAttribute('cy', y);
      pin.setAttribute('r', 2.6);
      pin.setAttribute('fill', '#67635b');
      pin.setAttribute('stroke', 'none');
      jackGroup.appendChild(pin);
    }
    for (let i = 0; i < 6; i++) {
      const [x1, y1] = JACKS[(i * 3) % JACKS.length];
      const [x2, y2] = JACKS[(i * 5 + 7) % JACKS.length];
      const sag = Math.max(y1, y2) + 80 + (i % 3) * 45;
      const path = document.createElementNS(NS, 'path');
      path.setAttribute('d', `M ${x1} ${y1} C ${x1} ${sag}, ${x2} ${sag}, ${x2} ${y2}`);
      path.setAttribute('stroke', CABLE_COLOR[i]);
      cableGroup.appendChild(path);
      if (animate) {
        const length = path.getTotalLength();
        path.style.strokeDasharray = String(length);
        path.animate(
          [{ strokeDashoffset: length }, { strokeDashoffset: 0 }],
          { duration: 1600, delay: i * 260, easing: 'ease-in-out', fill: 'both' }
        );
      }
    }
  }

  function startLog() {
    const codeNode = document.getElementById('build-code');
    const buffer = [SEED];
    const queue = [];
    let typing = false;
    const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));
    const render = () => {
      codeNode.textContent = buffer.join('\n');
    };
    render();

    async function drain() {
      typing = true;
      while (queue.length) {
        const line = queue.shift();
        buffer.push('');
        if (buffer.length > MAX_LINES) buffer.shift();
        let partial = '';
        for (const ch of line) {
          partial += ch;
          buffer[buffer.length - 1] = partial;
          render();
          if (!reduced) await wait(13);
        }
      }
      typing = false;
    }

    window.addEventListener('diplomacy:log', (event) => {
      if (queue.length > 10) return; // a storm of events keeps only its leading edge
      queue.push(event.detail);
      if (!typing) drain();
    });
  }

  function glyphBurst() {
    const scorebed = document.getElementById('build-scorebed');
    const score = createScoreLayer(scorebed);
    const rect = scorebed.getBoundingClientRect();
    const KINDS = ['gliss', 'squiggle', 'cluster', 'arc'];
    for (let i = 0; i < 7; i++) {
      setTimeout(() => {
        const x = 60 + Math.random() * (rect.width - 160);
        const y = 60 + Math.random() * (rect.height - 130);
        const kind = KINDS[i % KINDS.length];
        if (kind === 'arc') score.arc(x, y, Math.random() * 4 - 2, Math.random() * 2 - 1);
        else if (kind === 'gliss') score.gliss(x, y, 0.3 + Math.random() * 0.4);
        else if (kind === 'cluster') score.cluster(x, y, 0.3 + Math.random() * 0.3);
        else score.squiggle(x, y, 1400);
      }, 500 + i * 900);
    }
  }

  if (stage) {
    startLog();
    if (reduced || !('IntersectionObserver' in window)) {
      drawField(false);
    } else {
      const once = new IntersectionObserver((entries) => {
        if (!entries.some((entry) => entry.isIntersecting)) return;
        once.disconnect();
        drawField(true);
        glyphBurst();
      }, { threshold: 0.25 });
      once.observe(stage);

      // if the observer never reports, show everything rather than nothing
      setTimeout(() => {
        if (!stage.querySelector('.cable-paths path')) drawField(false);
      }, 4000);
    }
  }
</script>
